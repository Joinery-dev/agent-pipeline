{
  "maxQARounds": 3,
  "maxPMReplans": 2,
  "maxDesignRounds": 3,
  "maxBuildBatch": 5,
  "maxExecRestarts": 3,
  "progressCheckIntervalMs": 300000,
  "heartbeatIntervalMs": 30000,
  "maxChecksWithoutProgress": 2,
  "hooks": {
    "post-qa": [
      { "script": ".autoresearch/inline/collect.js", "args": ["--trigger", "post-qa"], "timeout": 5000 }
    ],
    "post-resolve": [
      { "script": ".autoresearch/inline/collect.js", "args": ["--trigger", "post-resolve"], "timeout": 5000 }
    ],
    "phase-complete": [
      { "script": ".autoresearch/inline/report.js", "args": ["--generate"], "timeout": 10000 }
    ]
  }
}
