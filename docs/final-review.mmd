---
title: "Final Product Review"
---

flowchart TD
    ALLDONE(("All Major\nPhases\nComplete"))

    ALLDONE --> TESTS

    subgraph TECHNICAL["Technical Checks"]
        direction LR

        TESTS["🧪 Full Test Suite\nAll tiers, cross-phase\nregressions"]

        TESTS --> PRODBUILD

        PRODBUILD["📦 Production Build\nnpm run build\nCatch SSR, type, import errors"]

        PRODBUILD --> LINKCHECK

        LINKCHECK["🔗 Link Check + Content Audit\nBroken links, orphaned pages\nPlaceholder text, broken images\nEmpty sections"]
    end

    LINKCHECK --> GRID

    GRID["📸 Screenshot Grid\nEvery page in one image\nWhole product at a glance"]

    GRID --> PLAN_JOURNEYS

    PLAN_JOURNEYS["🗺 Plan Walkthrough Journeys\nAgent reads what was built\nDesigns 3-5 product-specific\nuser journeys to test"]

    PLAN_JOURNEYS --> WALK

    subgraph WALKTHROUGHS["User Journey Walkthroughs -- fresh context each"]
        direction LR

        W1["🚶 Journey 1"]
        W2["🚶 Journey 2"]
        W3["🚶 Journey 3"]
        W4["🚶 ..."]
    end

    WALK[ ] --> W1
    WALK --> W2
    WALK --> W3
    WALK --> W4

    W1 --> REPORTS
    W2 --> REPORTS
    W3 --> REPORTS
    W4 --> REPORTS

    REPORTS([".qa/walkthroughs/\nNarrative findings\nfrom each journey"])

    REPORTS --> PROJECTQA

    PROJECTQA["🔍 Project-Level QA\nCross-page validation\nVision vs reality\nOverall completeness"]

    PROJECTQA --> PROJECTDESIGN

    PROJECTDESIGN["🎨 Project-Level Design Review\nCross-page consistency\nVisual language adherence\nOverall quality grading"]

    PROJECTDESIGN --> EXEC_START

    subgraph EXEC_REVIEW["Interactive Executive Final Review"]
        direction TB

        EXEC_START["📋 Read All Reports\nScreenshot grid, walkthroughs\nLink check, QA, design memory\nTest and build results"]

        EXEC_START --> RESEARCH

        RESEARCH["🌐 Fresh Competitive Research\nHow does the product compare\nto current competitors?"]

        RESEARCH --> OPEN

        OPEN["🖥 Open the Product\nStart dev server\nHuman sees it live"]

        OPEN --> PRESENT

        PRESENT["💬 Present Findings\nVision fulfillment\nWalkthrough issues\nCompetitive gaps\nBroken links and content issues\nQuality state"]

        PRESENT --> DISCUSS

        DISCUSS["💬 Improvement Conversation\nHuman reacts to findings\nDiscusses priorities\nDecides what matters"]
    end

    DISCUSS --> DECISION{"What does the\nhuman want?"}

    DECISION -- "Ship it" --> SHIP(("🏁\nProject\nShipped"))

    DECISION -- "Improve these areas" --> NEWPHASES

    NEWPHASES["🧠 Executive Creates\nNew Major Phases\nfor requested improvements"]

    NEWPHASES -- "pipeline restarts autonomously" --> BUILDLOOP

    BUILDLOOP(["Research, Plan\nBuild, QA, Design\nloop runs for\neach new phase"])

    BUILDLOOP --> ALLDONE

