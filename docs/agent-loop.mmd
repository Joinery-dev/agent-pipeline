---
title: "How the Pipeline Orchestrator Works"
---

flowchart TD
    START(("Start"))

    START --> HAS_STRUCTURE{"Does the project\nhave structure?"}

    HAS_STRUCTURE -- "no" --> EXEC_PLAN["💬 Executive talks to human\nDiscovers requirements\nResearches the space\nCreates vision, phases, contracts"]
    EXEC_PLAN --> HAS_STRUCTURE

    HAS_STRUCTURE -- "yes" --> FIND_WORK{"Find the next\npiece of work"}

    FIND_WORK -- "major phase needs planning" --> RESEARCH["🌐 Research best practices\nfor this phase"]
    RESEARCH --> PM_PLAN["📋 PM creates the plan\nSub-phases, tasks, visual spec\nMockup illustrations, diagrams"]
    PM_PLAN --> FIND_WORK

    FIND_WORK -- "phase needs building" --> BUILD

    subgraph CORE["Build, Verify, Review"]
        direction LR

        BUILD["🔨 Build\nImplement tasks\nWrite tests"]
        BUILD -- "screenshots + tests" --> QA
        QA["🔍 QA\nCheck criteria\nCompare to mockup"]
        QA -- "visual check" --> DESIGN
        DESIGN["🎨 Design Review\nSpec compliance\nConsistency"]
    end

    DESIGN -- "issues found" --> RESOLVE
    RESOLVE["🔧 Fix\nSurgical fixes from diagnosis"]
    RESOLVE --> QA

    DESIGN -- "approved" --> DONE_PHASE(("Phase\ndone"))

    QA -. "keeps failing" .-> REPLAN["📋 PM revises the plan\nwith failure details"]
    REPLAN -.-> BUILD
    REPLAN -. "still failing" .-> EXEC_ESC

    EXEC_ESC["🧠 Executive Escalation\nDiagnose root cause\nResearch alternatives"]
    EXEC_ESC -. "restart with new approach" .-> RESEARCH
    EXEC_ESC -. "cannot resolve" .-> HUMAN_STOP(("🛑\nHuman\nneeded"))

    DONE_PHASE --> IS_MAJOR{"Completed a\nmajor phase?"}

    IS_MAJOR -- "more sub-phases to build" --> FIND_WORK

    IS_MAJOR -- "yes, major phase done" --> CHECKPOINT["🧠 Executive Checkpoint\nRun tests, links, walkthrough\nVerify contracts, check vision\nCapture lessons, update conventions\nFlag issues for PM to fix"]
    CHECKPOINT --> FIND_WORK

    FIND_WORK -- "everything is built" --> FINAL

    subgraph FINAL["Final Product Review"]
        direction TB

        TECH_CHECKS["🧪📦🔗 Technical Checks\nTests, production build\nLinks, content audit"]
        TECH_CHECKS --> WALKTHROUGHS["🚶 User Journey Walkthroughs"]
        WALKTHROUGHS --> PROJECT_REVIEW["🔍🎨 Project-level QA + Design"]
        PROJECT_REVIEW --> EXEC_REVIEW["💬 Executive reviews with human\nCompetitive research\nPresent findings\nDiscuss improvements"]
    end

    EXEC_REVIEW --> SHIP_DECIDE{"Human\ndecision"}

    SHIP_DECIDE -- "Ship it" --> SHIPPED(("🏁\nShipped"))
    SHIP_DECIDE -- "Improve" --> NEW_PHASES["🧠 Executive creates\nimprovement phases"]
    NEW_PHASES --> FIND_WORK

