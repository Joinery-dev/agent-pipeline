---
title: "Executive Escalation Handling"
---

flowchart TD
    TRIGGER(("Pipeline\nStalled"))
    TRIGGER --> CONTEXT(["Trigger context\nQA exhaustion, design exhaustion\nzero progress, quality gate\npm-plan-failure"])

    CONTEXT --> READ

    READ["📋 Read Current State\nEscalation context from ship.js\n.goals.json: failing phase, attempts\nPlan file for the failing phase\nPM concerns and decisions\nQA status, patterns, regressions\nDesign findings"]

    READ --> HISTORY

    HISTORY["📂 Read Escalation History\n.exec/history/ JSON snapshots\n.exec/memory/escalation-log.md\nHas this phase failed before?\nWhat was tried? What changed?"]

    HISTORY --> RESEARCH

    RESEARCH{"Root cause\nlikely external?"}

    RESEARCH -- "yes, approach may be wrong" --> DEEP["🌐 Deep Research\n5-10 searches, WebFetch\nAlternative approaches\nWrite fresh research brief\nDelete stale brief"]

    RESEARCH -- "no, internal issue" --> QUICK["🔍 Quick Research\n1-3 targeted searches\nOr skip entirely"]

    DEEP --> DIAGNOSE
    QUICK --> DIAGNOSE

    DIAGNOSE["🔬 Diagnose Root Cause\nBad decomposition?\nWrong technical approach?\nMissing dependency?\nSpec too vague?\nDesign mismatch?\nContract violation?"]

    DIAGNOSE --> DEDUP

    DEDUP{"Same approach\nas a previous\nfailed RESTART?"}

    DEDUP -- "yes" --> FIND_ALT["Find a genuinely\ndifferent approach\nor CONTINUE"]
    DEDUP -- "no" --> DECIDE
    FIND_ALT --> DECIDE

    DECIDE{"RESTART or\nCONTINUE?"}

    DECIDE -- "CONTINUE" --> LOG_CONT["Log reasoning\nto .exec/memory/"]
    LOG_CONT --> CONT_OUT(("Pipeline\nresumes or\nstops"))

    DECIDE -- "RESTART" --> ACT

    subgraph ACT["Restructure"]
        direction TB

        UPDATE["Update major phase\ndescription and contracts"]
        UPDATE --> CLEAR["Clear sub-phases and tasks\nfor PM to replan"]
        CLEAR --> INSTALL["Install dependencies\nif needed"]
        INSTALL --> CONVENTIONS["Update conventions,\nvisual language, diagram\nif approach changed"]
        CONVENTIONS --> LESSONS["Write lessons to .exec/memory/\nWhat failed, why, what to avoid"]
    end

    LESSONS --> RESTART_OUT(("Pipeline\nrestarts with\nfresh research"))

