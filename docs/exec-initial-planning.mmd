---
title: "Executive Initial Planning"
---

flowchart TD
    START(("New\nProject"))
    START --> DISCOVER

    subgraph CONVERSATION["Interactive Discovery with Human"]
        direction TB

        DISCOVER["💬 Discover\nWhat are we building? Who is it for?\nWhat does done look like?"]

        DISCOVER --> SCOPE["💬 Scope and Priorities\nMust-haves vs nice-to-haves\nReference products or websites\nWhat they do NOT want"]

        SCOPE --> BRAND["💬 Design and Brand\nExisting guidelines, colors, logo?\nDesired mood and personality\nSites they admire"]

        BRAND --> TECHCTX["💬 Technical Context\nFramework or hosting constraints\nExternal integrations needed\nPerformance requirements"]

        TECHCTX --> CONFIRM["💬 Summarize Understanding\nPlay back what was heard\nHuman confirms or corrects"]

        CONFIRM -- "not quite right" --> DISCOVER
    end

    CONFIRM -- "confirmed" --> EXPLORE

    EXPLORE["🔎 Explore Codebase\nWhat already exists?\nFrameworks, patterns, data models\nNatural seams and dependencies"]

    EXPLORE --> RESEARCH

    RESEARCH["🌐 Research the Space\nCompetitors and how they structure features\nBest practices and common pitfalls\nTechnical approaches others use\nDesign conventions users expect"]

    RESEARCH --> BRIEF(["Write research brief\nPM reads this when\nplanning each phase"])

    BRIEF --> VISION

    VISION["📌 Set the Vision\nConcrete, testable definition of done\nDerived from discovery conversation"]

    VISION --> DECOMPOSE

    subgraph DECOMPOSE["Decompose into Major Phases"]
        direction TB

        MAP_USER["🧑 Map User Capabilities\nWhat can users DO?\nGroup into demoable units\nMatch competitor feature structure"]

        MAP_USER --> MAP_TECH

        MAP_TECH["🔧 Map Technical Reality\nIdentify shared infrastructure\nPhase 1 owns shared files\nName every contract boundary"]

        MAP_TECH --> ORDER

        ORDER["📊 Order by Risk\nWalking skeleton first\nRisky work early\nMaximize parallelism"]

        ORDER --> PRESSURE

        PRESSURE["🔍 Pressure-Test\nCan I demo each phase alone?\nDoes builder have everything\nfrom prior contracts?\nCan PM split into 2-5 sub-phases?"]
    end

    PRESSURE --> CONTRACTS(["Interface Contracts\nEvery phase has produces and consumes\nExact names, routes, components"])

    CONTRACTS --> ISUI{"UI project?"}

    ISUI -- "yes" --> VLANG
    ISUI -- "no" --> DIAGRAM

    VLANG["🎨 Visual Language\nPalette, typography, spacing\nComponent patterns, mood\nAll from discovery conversation"]

    VLANG --> DIAGRAM

    DIAGRAM["📐 Architecture Diagram\nProduct structure, not work plan\nNodes are components, pages, APIs\nMultiple diagrams if useful"]

    DIAGRAM --> HASUI{"UI project?"}

    HASUI -- "yes" --> MOCKUP
    HASUI -- "no" --> VALIDATE

    MOCKUP["🖼 Project Illustration\nHigh-level mockup of main page\nUses visual language tokens\nParent that phase mockups zoom into"]

    MOCKUP --> VALIDATE

    VALIDATE["Validate Structure\nContracts complete, no cycles\nPhase 1 is a walking skeleton\nRiskiest phase is not last\nWalk each contract from builder POV"]

    VALIDATE --> DONE(("Pipeline\nReady"))

    DONE --> HANDOFF(["ship.js takes over\nFully autonomous from here\nPM plans, Builder builds\nQA validates, Design reviews"])

