    style ADJUST fill:#162744,stroke:#4a7fc9,stroke-width:1.5px,color:#dce8f5
    style UPDATE_VL fill:#2a183a,stroke:#9050b6,stroke-width:1.5px,color:#e8d8f5
    style LESSONS fill:#2a1a10,stroke:#c98a4a,stroke-width:2px,color:#f5e8d4
